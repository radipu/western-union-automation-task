<Window x:Class="WesternUnionAutomationTask.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ParaBank Automation" Height="700" Width="1080"
        MinHeight="680" MinWidth="980"
        WindowStartupLocation="CenterScreen" Background="#F5F8FB">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="24" Padding="28" Margin="0,0,0,20">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#102A43" Offset="0" />
                    <GradientStop Color="#2F80ED" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="ParaBank Process Automation" FontSize="31" FontWeight="Bold" Foreground="White" />
                    <TextBlock Margin="0,8,0,0" FontSize="14" Foreground="#DDEBFF"
                               Text="Register customers, open accounts, request loans, and generate the operator report from one clean desktop screen." />
                </StackPanel>
                <Border Grid.Column="1" Background="#22FFFFFF" CornerRadius="16" Padding="16,10" VerticalAlignment="Center">
                    <TextBlock Text="C# · Selenium · Excel" Foreground="White" FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1.3*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Input file" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock x:Name="SelectedFileText" Margin="0,8,0,0" Foreground="{StaticResource MutedTextBrush}" Text="No CSV or Excel file selected." TextWrapping="Wrap" />
                    <TextBlock x:Name="SummaryText" Margin="0,8,0,0" Foreground="#334E68" Text="Select the ParaBank users file to validate records before automation starts." />
                </StackPanel>

                <UniformGrid Grid.Column="1" Columns="3" Margin="26,0,20,0">
                    <Border Background="#F0F7FF" CornerRadius="14" Padding="14" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Records" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="TotalRecordsText" Text="0" FontSize="28" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    <Border Background="#F0FFF4" CornerRadius="14" Padding="14" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Ready" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="ReadyRecordsText" Text="0" FontSize="28" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    <Border Background="#FFF5F5" CornerRadius="14" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Skipped" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="SkippedRecordsText" Text="0" FontSize="28" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Select File" Click="SelectCsv_Click" />
                    <Button x:Name="StartButton" Content="Start" Click="StartAutomation_Click" IsEnabled="False" Style="{StaticResource SuccessButtonStyle}" />
                    <Button x:Name="CancelButton" Content="Cancel" Click="CancelAutomation_Click" IsEnabled="False" Style="{StaticResource DangerButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.08*" />
                <ColumnDefinition Width="1.4*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,20,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Run settings" FontSize="18" FontWeight="SemiBold" />
                    <StackPanel Grid.Row="1" Margin="0,16,0,18">
                        <TextBlock x:Name="ParaBankUrlText" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                        <TextBlock x:Name="LoanAmountText" Margin="0,8,0,0" Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock x:Name="DownPaymentText" Margin="0,8,0,0" Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock x:Name="CurrencyRateText" Margin="0,8,0,0" Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                    <Border Grid.Row="2" Background="#F8FBFE" CornerRadius="14" Padding="16">
                        <TextBlock TextWrapping="Wrap" Foreground="#334E68"
                                   Text="The automation validates the uploaded file first. Invalid records are skipped safely and still appear in the Excel report with the reason, so the run can continue without crashing." />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel>
                        <TextBlock Text="Execution log" FontSize="18" FontWeight="SemiBold" DockPanel.Dock="Left" />
                        <TextBlock x:Name="ProgressPercentText" Text="0%" Foreground="{StaticResource MutedTextBrush}" DockPanel.Dock="Right" VerticalAlignment="Center" />
                    </DockPanel>
                    <ProgressBar x:Name="RunProgress" Grid.Row="1" Height="10" Minimum="0" Maximum="100" Margin="0,16,0,14" />
                    <ListBox x:Name="LogList" Grid.Row="2" BorderBrush="{StaticResource SoftBorderBrush}" />
                </Grid>
            </Border>
        </Grid>

        <DockPanel Grid.Row="3" Margin="0,18,0,0">
            <TextBlock x:Name="StatusText" Text="Ready" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
            <Button x:Name="OpenReportButton" DockPanel.Dock="Right" Content="Open Report Folder" Click="OpenReportFolder_Click" IsEnabled="False" Style="{StaticResource SecondaryButtonStyle}" />
        </DockPanel>
    </Grid>
</Window>
